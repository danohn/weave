ADMIN_TOKEN=changeme

# Domain Traefik will route to the dashboard and API
WEAVE_DOMAIN=weave.example.com

# Optional: Traefik middleware chain to apply to both routers (e.g. auth, IP allowlist)
# Leave empty or omit to apply no middleware
TRAEFIK_MIDDLEWARE=

# Optional: override the default VPN subnet
# VPN_SUBNET=10.0.0.0/24
