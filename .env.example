# Domain Traefik routes to the dashboard and API
WEAVE_DOMAIN=weave.example.com

# Session signing key — use a long random string in production
SESSION_SECRET=changeme-session-secret

# Optional: force Secure session cookies on or off.
# Defaults to true when WEAVE_DOMAIN is set, false otherwise.
# SESSION_COOKIE_SECURE=true

# OIDC provider (e.g. Authentik, Keycloak, Dex)
OIDC_ISSUER=https://auth.example.com/application/o/weave
OIDC_CLIENT_ID=weave
OIDC_CLIENT_SECRET=changeme-client-secret

# Optional: OIDC group required for admin access
# OIDC_ADMIN_GROUP=weave-admins

# Optional: override the OIDC callback URL (auto-derived from WEAVE_DOMAIN if unset)
# OIDC_REDIRECT_URI=https://weave.example.com/auth/callback

# Bearer token for agent-facing admin endpoints (claims, node management)
ADMIN_TOKEN=changeme

# Existing-Traefik mode only: Docker network shared with your Traefik container
TRAEFIK_NETWORK=backend

# Optional: Traefik middleware chain for API routes
# TRAEFIK_MIDDLEWARE=chain-internal@file

# Optional: Traefik middleware chain for the dashboard (falls back to TRAEFIK_MIDDLEWARE)
# TRAEFIK_MIDDLEWARE_UI=

# Optional: override the default VPN subnet
# VPN_SUBNET=10.0.0.0/24
